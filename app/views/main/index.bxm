	<a class="block min-h-[230px] rounded-lg border border-line bg-panel p-5 no-underline shadow-panel transition hover:-translate-y-0.5 hover:border-blue max-demo:min-h-[180px]" href="#event.buildLink( "tests" )#" target="_blank">
