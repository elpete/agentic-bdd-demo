<bx:output>
<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="description" content="Agentic BDD/TDD demo for Conference Session Review and CFP scoring">
	<base href="#event.getHTMLBaseURL()#" />
	<link rel="stylesheet" href="includes/css/app.css">
	<title>#encodeForHTML( prc.pageTitle ?: "Agentic BDD/TDD Demo" )#</title>
</head>
<body class="m-0 bg-paper font-sans text-ink leading-[1.55]">
	<header class="sticky top-0 z-[2] border-b border-line bg-paper/95">
		<nav class="mx-auto flex max-w-shell items-center justify-between gap-4 px-6 py-4 max-demo:block" aria-label="Main navigation">
			<a class="font-extrabold text-green no-underline hover:underline hover:underline-offset-4" href="#event.buildLink( "" )#">Agentic BDD</a>
			<div class="flex flex-wrap items-center justify-end gap-x-2 gap-y-[0.35rem] max-demo:mt-3 max-demo:justify-start">
				<a class="rounded-md px-3 py-2 text-[0.95rem] font-semibold text-muted no-underline hover:bg-code hover:text-ink" href="#event.buildLink( "" )#">Home</a>
				<a class="rounded-md px-3 py-2 text-[0.95rem] font-semibold text-muted no-underline hover:bg-code hover:text-ink" href="#event.buildLink( "sessions" )#">Scenario</a>
				<a class="rounded-md px-3 py-2 text-[0.95rem] font-semibold text-muted no-underline hover:bg-code hover:text-ink" href="#event.buildLink( "tests" )#" target="_blank">Tests</a>
				<a class="rounded-md px-3 py-2 text-[0.95rem] font-semibold text-muted no-underline hover:bg-code hover:text-ink" href="#event.buildLink( "route-visualizer" )#">Routes</a>
			</div>
		</nav>
	</header>

	<main class="mx-auto max-w-shell px-6 pb-20 pt-12 max-demo:pt-6">
		#view()#
	</main>
</body>
</html>
</bx:output>
