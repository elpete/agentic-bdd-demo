class extends="coldbox.system.testing.BaseTestCase" appMapping="/app" {

	function beforeAll(){
		super.beforeAll();
	}

	function run(){
		describe( "Sessions handler", () => {
			beforeEach( () => {
				setup();
			} );

			it( "prepares a sample decision for the demo session", () => {
				var event = execute( event = "sessions.index" );
				var result = event.getValue( name = "decision", private = true );

				expect( result.status ).toBe( "accepted" );
				expect( result.eligibleReviewCount ).toBe( 3 );
			} );
		} );
	}

}
