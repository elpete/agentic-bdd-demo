class extends="testbox.system.BaseSpec" {

	function run(){
		describe( "SessionDecisionService", () => {
			beforeEach( () => {
				variables.service = new app.models.SessionDecisionService();
			} );

			it( "keeps a draft session out of final decision making", () => {
				// Given
				var proposal = validSession();

				// When
				var decision = variables.service.decide( proposal );

				// Then
				expect( decision.status ).toBe( "draft" );
				expect( decision.eligibleReviewCount ).toBe( 0 );
			} );

			it( "accepts a submitted session when the average equals the acceptance threshold", () => {
				// Given
				var proposal = submittedSession()
					.addReview( completedReview( "alex", 4, 4, 4, 4 ) )
					.addReview( completedReview( "blair", 4, 4, 4, 4 ) )
					.addReview( completedReview( "casey", 4, 4, 4, 4 ) );

				// When
				var decision = variables.service.decide( proposal );

				// Then
				expect( decision.status ).toBe( "accepted" );
				expect( decision.averageScore ).toBe( 4 );
				expect( decision.eligibleReviewCount ).toBe( 3 );
			} );

			it( "waitlists a submitted session when the average equals the waitlist threshold", () => {
				// Given
				var proposal = submittedSession()
					.addReview( completedReview( "alex", 3, 3, 3, 3 ) )
					.addReview( completedReview( "blair", 3, 3, 3, 3 ) )
					.addReview( completedReview( "casey", 3, 3, 3, 3 ) );

				// When
				var decision = variables.service.decide( proposal );

				// Then
				expect( decision.status ).toBe( "waitlisted" );
				expect( decision.averageScore ).toBe( 3 );
			} );

			it( "rejects a submitted session below the waitlist threshold", () => {
				// Given
				var proposal = submittedSession()
					.addReview( completedReview( "alex", 2, 2, 2, 2 ) )
					.addReview( completedReview( "blair", 2, 2, 2, 2 ) )
					.addReview( completedReview( "casey", 2, 2, 2, 2 ) );

				// When
				var decision = variables.service.decide( proposal );

				// Then
				expect( decision.status ).toBe( "rejected" );
			} );

			it( "waitlists an otherwise strong session until it has enough eligible reviews", () => {
				// Given
				var proposal = submittedSession()
					.addReview( completedReview( "alex", 5, 5, 5, 5 ) )
					.addReview( completedReview( "blair", 5, 5, 5, 5 ) );

				// When
				var decision = variables.service.decide( proposal );

				// Then
				expect( decision.status ).toBe( "waitlisted" );
				expect( decision.reason ).toInclude( "Not enough" );
				expect( decision.eligibleReviewCount ).toBe( 2 );
			} );

			it( "ignores incomplete and conflicted reviews when calculating the final decision", () => {
				// Given
				var proposal = submittedSession()
					.addReview( completedReview( "alex", 4, 4, 4, 4 ) )
					.addReview( completedReview( "blair", 4, 4, 4, 4 ) )
					.addReview( completedReview( "casey", 4, 4, 4, 4 ) )
					.addReview( incompleteReview( "devon", 1, 1, 1, 0 ) )
					.addReview( conflictedReview( "emery", 1, 1, 1, 1 ) );

				// When
				var decision = variables.service.decide( proposal );

				// Then
				expect( decision.status ).toBe( "accepted" );
				expect( decision.averageScore ).toBe( 4 );
				expect( decision.eligibleReviewCount ).toBe( 3 );
			} );
		} );
	}

	private any function validSession(){
		return new app.models.Session(
			title = "Testing With Agents",
			abstract = "How BDD language keeps generated tests connected to user-visible behavior.",
			speaker = new app.models.Speaker(
				name = "Jordan Lee",
				email = "jordan@example.test",
				bio = "ColdBox developer and testing enthusiast."
			),
			category = "Testing"
		);
	}

	private any function submittedSession(){
		return validSession().submit();
	}

	private any function completedReview(
		required string reviewer,
		required numeric clarity,
		required numeric relevance,
		required numeric originality,
		required numeric confidence
	){
		return new app.models.Review(
			reviewer = arguments.reviewer,
			submitted = true,
			scoreCard = new app.models.ScoreCard(
				clarity = arguments.clarity,
				relevance = arguments.relevance,
				originality = arguments.originality,
				confidence = arguments.confidence
			)
		);
	}

	private any function incompleteReview(
		required string reviewer,
		required numeric clarity,
		required numeric relevance,
		required numeric originality,
		required numeric confidence
	){
		return new app.models.Review(
			reviewer = arguments.reviewer,
			submitted = false,
			scoreCard = new app.models.ScoreCard(
				clarity = arguments.clarity,
				relevance = arguments.relevance,
				originality = arguments.originality,
				confidence = arguments.confidence
			)
		);
	}

	private any function conflictedReview(
		required string reviewer,
		required numeric clarity,
		required numeric relevance,
		required numeric originality,
		required numeric confidence
	){
		return new app.models.Review(
			reviewer = arguments.reviewer,
			submitted = true,
			conflict = true,
			scoreCard = new app.models.ScoreCard(
				clarity = arguments.clarity,
				relevance = arguments.relevance,
				originality = arguments.originality,
				confidence = arguments.confidence
			)
		);
	}

}
